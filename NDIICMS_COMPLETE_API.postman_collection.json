								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('authToken', response.token);",
									"    pm.collectionVariables.set('adminEmail', response.email);",
									"    pm.collectionVariables.set('adminRole', response.role);",
									"    pm.collectionVariables.set('adminProfileId', response.profileId);",
